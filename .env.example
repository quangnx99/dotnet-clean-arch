# Postgres
POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=dotnetcleanarch;Username=postgres;Password=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ISSUER=dotnet-clean-arch
JWT_AUDIENCE=dotnet-clean-arch
JWT_SECRET=change-me-in-production-use-32-chars!!

# Runtime
ASPNETCORE_ENVIRONMENT=Development

# Used by docker-compose only (not consumed directly by the app)
POSTGRES_DB=dotnetcleanarch
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
