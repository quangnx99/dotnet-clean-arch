{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.AspNetCore": "Information",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Postgres": {
    "Host": "localhost",
    "Port": 5432,
    "Database": "dotnetcleanarch",
    "Username": "postgres",
    "Password": "postgres",
    "IncludeErrorDetail": true
  },
  "Redis": {
    "Host": "localhost",
    "Port": 6379,
    "Password": null,
    "Database": 0,
    "Ssl": false,
    "InstanceName": "dotnet-clean-arch:",
    "ConnectTimeoutMs": 5000,
    "AbortOnConnectFail": false
  },
  "Jwt": {
    "Issuer": "dotnet-clean-arch",
    "Audience": "dotnet-clean-arch",
    "SecretKey": "dev-secret-key-change-in-production-32chars-minimum",
    "ExpiryMinutes": 1440
  }
}
